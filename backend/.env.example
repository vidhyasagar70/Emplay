PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:4200
MONGODB_URI=mongodb://127.0.0.1:27017/ai_prompts
REDIS_URL=redis://localhost:6379
# Optional alternatives to REDIS_URL:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=
# Set true to run backend without Redis in development.
# DISABLE_REDIS=false
JWT_SECRET=replace-with-a-secure-secret
JWT_EXPIRES_IN=1d
AUTH_USERNAME=admin
AUTH_PASSWORD=admin123
